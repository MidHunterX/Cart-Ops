  "fixed_sql": [
    {
      "name": "groups",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"groups\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"description\" TEXT NULL, \"icon_key\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "purchases",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"purchases\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"purchase_date\" INTEGER NOT NULL, \"total_price\" REAL NULL, \"tax_rate\" REAL NULL, \"budget\" REAL NULL, \"is_checklist_mode\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_checklist_mode\" IN (0, 1)), \"group_id\" INTEGER NULL REFERENCES \"groups\" (id) ON DELETE CASCADE);"
        }
      ]
    },
    {
      "name": "items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"items\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"image_path\" TEXT NULL, \"group_id\" INTEGER NULL REFERENCES \"groups\" (id) ON DELETE CASCADE);"
        }
      ]
    },
    {
      "name": "purchased_items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"purchased_items\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NULL, \"image_path\" TEXT NULL, \"price\" REAL NULL, \"is_weight\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_weight\" IN (0, 1)), \"quantity\" REAL NULL, \"discount\" REAL NOT NULL DEFAULT 0.0, \"is_checked\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_checked\" IN (0, 1)), \"purchase_id\" INTEGER NOT NULL REFERENCES purchases (id) ON DELETE CASCADE, \"item_id\" INTEGER NULL REFERENCES items (id) ON DELETE CASCADE);"
        }
      ]
    }
  ]
